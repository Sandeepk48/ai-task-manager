# --- Required ---
# PostgreSQL (local or cloud e.g. Neon, Supabase, Render Postgres, Railway Postgres)
# Use SSL for most cloud providers (?sslmode=require often appended by the host)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Strong secret for signing JWTs (min ~32 random bytes in production)
JWT_SECRET="change-me-to-a-long-random-string"

# --- Production CORS (pick one approach) ---
# Single deployed frontend URL (no trailing slash)
FRONTEND_URL="https://your-frontend.example.com"

# Optional: override with multiple comma-separated origins (staging + prod)
# CORS_ORIGINS="https://app.example.com,https://staging.example.com"

# --- Server ---
# Render/Railway inject PORT; default 4000 for local dev
PORT=4000
NODE_ENV=development

# --- Optional ---
JWT_EXPIRES_IN="7d"
# AI summaries: set a real key, or omit OPENAI_API_KEY entirely. Never OPENAI_API_KEY=""
# (empty string in .env is loaded into process.env and blocks AI the same as no key).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
